    // ─── ЧАСТИЦЫ ───
    const canvas = document.getElementById('particlesCanvas');
    const ctx = canvas.getContext('2d');
    let w, h;
    const particles = [];
    const COUNT = 130;
    const COLORS = ['#825AFF', '#A57AFF', '#FF6B9D', '#FFCD37', '#46DC78', '#46A5FF'];

    function resize() {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
    }
    window.addEventListener('resize', resize);
    resize();

    class Particle {
        constructor() { this.reset(); }
        reset() {
            this.x = Math.random() * w;
            this.y = Math.random() * h;
            this.size = Math.random() * 3 + 1.5;
            this.speedX = (Math.random() - 0.5) * 0.7;
            this.speedY = (Math.random() - 0.5) * 0.7;
            this.color = COLORS[Math.floor(Math.random() * COLORS.length)];
            this.alpha = Math.random() * 0.5 + 0.3;
            this.pulse = Math.random() * Math.PI * 2;
        }
        update() {
            this.x += this.speedX;
            this.y += this.speedY;
            this.pulse += 0.02;
            if (this.x < 0) this.x = w;
            if (this.x > w) this.x = 0;
            if (this.y < 0) this.y = h;
            if (this.y > h) this.y = 0;
            this.currentSize = this.size + Math.sin(this.pulse) * 0.6;
        }
        draw() {
            ctx.beginPath();
            ctx.arc(this.x, this.y, Math.max(0.5, this.currentSize), 0, Math.PI * 2);
            ctx.fillStyle = this.color;
            ctx.globalAlpha = this.alpha + Math.sin(this.pulse) * 0.15;
            ctx.fill();
            ctx.globalAlpha = 1;
        }
    }

    for (let i = 0; i < COUNT; i++) particles.push(new Particle());

    function drawLines() {
        for (let i = 0; i < particles.length; i++) {
            for (let j = i + 1; j < particles.length; j++) {
                const dx = particles[i].x - particles[j].x;
                const dy = particles[i].y - particles[j].y;
                const dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < 120) {
                    ctx.beginPath();
                    ctx.moveTo(particles[i].x, particles[i].y);
                    ctx.lineTo(particles[j].x, particles[j].y);
                    ctx.strokeStyle = '#825AFF';
                    ctx.globalAlpha = 0.08 * (1 - dist / 120);
                    ctx.lineWidth = 1;
                    ctx.stroke();
                    ctx.globalAlpha = 1;
                }
            }
        }
    }

    function animate() {
        ctx.clearRect(0, 0, w, h);
        particles.forEach(p => { p.update(); p.draw(); });
        drawLines();
        requestAnimationFrame(animate);
    }
    animate();

    window.addEventListener('resize', () => {
        resize();
        particles.forEach(p => {
            p.x = Math.random() * w;
            p.y = Math.random() * h;
        });
    });

    // ─── ПЛАВНЫЙ СКРОЛЛ ───
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({ behavior: 'smooth' });
            }
        });
    });

    // ─── ТОСТ ───
    const toastEl = document.getElementById('toast');
    let toastTimeout;

    function showToast(msg, type = 'info') {
        toastEl.textContent = msg;
        toastEl.className = 'toast show';
        toastEl.style.background = type === 'error' ? 'rgba(255,60,60,0.9)' :
            type === 'info' ? 'rgba(130,90,255,0.9)' :
            'rgba(70,220,120,0.9)';
        toastEl.style.color = type === 'error' || type === 'info' ? '#fff' : '#0a0a12';
        clearTimeout(toastTimeout);
        toastTimeout = setTimeout(() => {
            toastEl.classList.remove('show');
        }, 3000);
    }

    // ─── АЧИВКИ ───
    let achievements = {
        firstClick: { name: '👣 Первый шаг', desc: 'Сделать первый клик', unlocked: false, icon: '👣' },
        thousandClicks: { name: '📈 Тысячник', desc: '1000 кликов', unlocked: false, icon: '📈' },
        millionPoints: { name: '💎 Миллионер', desc: '1 000 000 очков', unlocked: false, icon: '💎' },
        collector: { name: '🐾 Коллекционер', desc: '10 питомцев', unlocked: false, icon: '🐾' },
        prestigeMaster: { name: '⭐ Мастер престижа', desc: '5 престижей', unlocked: false, icon: '⭐' },
        gamer: { name: '🎮 Игроман', desc: '100 побед в мини-игре', unlocked: false, icon: '🎮' },
        critMaster: { name: '⚡ Критический удар', desc: '50 критических ударов', unlocked: false, icon: '⚡' },
        petCollector: { name: '🌟 Легендарный коллекционер', desc: 'Все редкие питомцы', unlocked: false,
        icon: '🌟' },
    };

    let miniGameWins = 0;
    let totalCrits = 0;

    function unlockAchievement(id) {
        if (achievements[id] && !achievements[id].unlocked) {
            achievements[id].unlocked = true;
            playAchievementSound();
            const popup = document.getElementById('achievementPopup');
            document.getElementById('achIcon').textContent = achievements[id].icon;
            document.getElementById('achTitle').textContent = '🏆 ' + achievements[id].name;
            document.getElementById('achDesc').textContent = achievements[id].desc;
            popup.classList.add('show');
            showToast('🏆 Достижение: ' + achievements[id].name + '!', 'info');
            setTimeout(() => popup.classList.remove('show'), 4000);
            saveGame();
        }
    }

    function checkAchievements() {
        if (totalClicks >= 1) unlockAchievement('firstClick');
        if (totalClicks >= 1000) unlockAchievement('thousandClicks');
        if (points >= 1000000) unlockAchievement('millionPoints');
        if (pets.length >= 10) unlockAchievement('collector');
        if (prestigeLevel >= 5) unlockAchievement('prestigeMaster');
        if (miniGameWins >= 100) unlockAchievement('gamer');
        if (totalCrits >= 50) unlockAchievement('critMaster');
        const rarePets = pets.filter(p => p.rarity === 'legendary' || p.rarity === 'divine' || p.rarity === 'secret');
        if (rarePets.length >= 3) unlockAchievement('petCollector');
    }

    function renderAchievements() {
        const list = document.getElementById('achievementsList');
        list.innerHTML = '';
        for (const [id, ach] of Object.entries(achievements)) {
            const div = document.createElement('div');
            div.style.cssText = `
                        display:flex; align-items:center; gap:12px;
                        padding:10px 12px; margin-bottom:6px;
                        background:${ach.unlocked ? 'rgba(70,220,120,0.08)' : 'rgba(255,255,255,0.02)'};
                        border-radius:10px;
                        border:1px solid ${ach.unlocked ? 'rgba(70,220,120,0.15)' : 'rgba(255,255,255,0.04)'};
                        transition:0.2s;
                    `;
            div.innerHTML = `
                        <span style="font-size:24px;">${ach.unlocked ? ach.icon : '🔒'}</span>
                        <div style="flex:1;">
                            <div style="font-weight:600;font-size:14px;color:${ach.unlocked ? '#46DC78' : 'rgba(255,255,255,0.4)'};">${ach.unlocked ? '✅ ' : ''}${ach.name}</div>
                            <div style="font-size:11px;color:rgba(255,255,255,0.3);">${ach.desc}</div>
                        </div>
                        <span style="font-size:12px;color:${ach.unlocked ? '#46DC78' : 'rgba(255,255,255,0.15)'};">${ach.unlocked ? '✓' : '⏳'}</span>
                    `;
            list.appendChild(div);
        }
    }

    // ─── СОБЫТИЯ ───
    function getActiveEvent() {
        const now = new Date();
        const hour = now.getHours();
        const day = now.getDay();

        if (hour >= 8 && hour < 10) {
            return { name: '☀️ Утренний буст', bonus: 1.5, desc: '+50% очков с 8:00 до 10:00' };
        }
        if (hour >= 20 && hour < 22) {
            return { name: '🌙 Вечерний марафон', bonus: 2, desc: 'x2 очков с 20:00 до 22:00' };
        }
        if (day === 6 || day === 0) {
            return { name: '🎉 Выходной бонус', bonus: 2, desc: 'x2 очков по выходным!' };
        }
        return { name: '📅 Обычный день', bonus: 1, desc: 'Стандартные очки' };
    }

    let currentEvent = getActiveEvent();

    function updateEventDisplay() {
        currentEvent = getActiveEvent();
        const el = document.getElementById('eventDisplay');
        if (el) {
            el.textContent = `${currentEvent.name} — ${currentEvent.desc}`;
            if (currentEvent.bonus > 1) {
                el.style.color = '#FFD700';
            } else {
                el.style.color = 'rgba(255,255,255,0.5)';
            }
        }
    }

    // ─── ИГРОВАЯ ЛОГИКА ───
    let points = 0;
    let prestigeLevel = 0;
    let prestigeBonus = 1;
    let totalClicks = 0;

    let pets = [];
    let equippedPets = [];
    const MAX_EQUIPPED = 3;

    const PET_RARITIES = [
        { id: 'common', name: 'Обычный', color: '#aaaabc', mult: 0.2 },
        { id: 'rare', name: 'Редкий', color: '#50a0ff', mult: 0.5 },
        { id: 'epic', name: 'Эпический', color: '#aa50ff', mult: 1.2 },
        { id: 'mythic', name: 'Мифический', color: '#ff3c5a', mult: 3.0 },
        { id: 'legendary', name: 'Легендарный', color: '#ffc828', mult: 7.0 },
        { id: 'divine', name: 'Божественный', color: '#ffffff', mult: 15.0 },
        { id: 'secret', name: 'Секретный', color: '#ff0096', mult: 40.0 },
    ];

    const PET_SPECIES = {
        common: [{ name: 'Котёнок', icon: '🐱' }, { name: 'Щенок', icon: '🐶' }, { name: 'Кролик', icon: '🐰' }],
        rare: [{ name: 'Лиса', icon: '🦊' }, { name: 'Сова', icon: '🦉' }, { name: 'Енот', icon: '🦝' }],
        epic: [{ name: 'Волк', icon: '🐺' }, { name: 'Тигр', icon: '🐯' }, { name: 'Орёл', icon: '🦅' }],
        mythic: [{ name: 'Дракончик', icon: '🐉' }, { name: 'Феникс', icon: '🔥' }, { name: 'Единорог', icon: '🦄' }],
        legendary: [{ name: 'Кракен', icon: '🐙' }, { name: 'Грифон', icon: '🦁' }, { name: 'Левиафан', icon: '🐳' }],
        divine: [{ name: 'Ангел', icon: '👼' }, { name: 'Серафим', icon: '😇' }, { name: 'Титан', icon: '⚡' }],
        secret: [{ name: 'Аномалия', icon: '👁' }, { name: 'Пустота', icon: '🌌' }, { name: 'Сингулярность', icon: '🕳' }],
    };

    const CODES = {
        'WELCOME': { points: 5000, desc: 'Стартовый бонус!' },
        'CLICKMASTER': { points: 25000, desc: 'Ты мастер кликов!' },
        'BOOST100': { points: 0, mult: 2, desc: 'Буст x2 на 5 минут!' },
        'RICHLIFE': { points: 100000, desc: 'Богатая жизнь!' },
        'DARKNESS': { points: 50000, desc: 'Из тьмы — свет!' },
        'SCIFI2077': { points: 75000, desc: 'Будущее уже здесь!' },
        'NATURE': { points: 30000, desc: 'Сила природы!' },
        'LEGEND': { points: 500000, desc: 'Только для легенд!' },
        'DEVELOPER': { points: 1000000, desc: 'Секретный код!' },
    };
    let usedCodes = [];

    let rewardTimer = 300;
    let rewardReady = false;
    let rewardPoints = 0;
    let boostMult = 1;
    let boostTimer = 0;

    const UPGRADES = [
        { id: 'multiplier', name: 'Множитель', icon: '✦', effect: 'multiplier', value: 1, baseCost: 50, costMult: 2.5 },
        { id: 'autoclicker', name: 'Автокликер', icon: '◎', effect: 'passive', value: 1, baseCost: 100, costMult: 2.0 },
        { id: 'critchance', name: 'Крит', icon: '⚡', effect: 'crit', value: 0.05, baseCost: 200, costMult: 3.0 },
        { id: 'megaclick', name: 'Мегаклик', icon: '◆', effect: 'perclick', value: 2, baseCost: 500, costMult: 2.2 },
        { id: 'dragonbreath', name: 'Дракон', icon: '🐉', effect: 'perclick', value: 10, baseCost: 2000, costMult: 2.6 },
    ];

    let upgrades = {};
    UPGRADES.forEach(u => upgrades[u.id] = 0);

    // DOM
    const heroPoints = document.getElementById('heroPoints');
    const heroPower = document.getElementById('heroPower');
    const heroPassive = document.getElementById('heroPassive');
    const heroPrestige = document.getElementById('heroPrestige');

    const gPoints = document.getElementById('gPoints');
    const gPower = document.getElementById('gPower');
    const gPassive = document.getElementById('gPassive');
    const gPrestige = document.getElementById('gPrestige');
    const gPointsDisplay = document.getElementById('gPointsDisplay');
    const gPreInfo = document.getElementById('gPreInfo');
    const gPreBonus = document.getElementById('gPreBonus');
    const gPreCost = document.getElementById('gPreCost');
    const shopGrid = document.getElementById('shopGrid');
    const petsGrid = document.getElementById('petsGrid');
    const rewardTimerEl = document.getElementById('rewardTimer');
    const claimBtn = document.getElementById('claimBtn');

    function fmt(n) {
        if (n >= 1e9) return (n / 1e9).toFixed(1) + 'Млрд';
        if (n >= 1e6) return (n / 1e6).toFixed(1) + 'Млн';
        if (n >= 1e3) return (n / 1e3).toFixed(1) + 'Тыс';
        return Math.floor(n).toString();
    }

    function getRarity(id) { return PET_RARITIES.find(r => r.id === id) || PET_RARITIES[0]; }

    function getPetBonus() {
        let total = 0;
        for (let i = 0; i < equippedPets.length; i++) {
            total += getRarity(pets[equippedPets[i]].rarity).mult;
        }
        return total;
    }

    function getMultiplier() {
        let mult = 1;
        UPGRADES.forEach(u => {
            if (u.effect === 'multiplier') mult += upgrades[u.id] * u.value;
        });
        mult += getPetBonus();
        mult *= prestigeBonus;
        return mult;
    }

    function getPerClick() {
        let base = 1;
        UPGRADES.forEach(u => {
            if (u.effect === 'perclick') base += upgrades[u.id] * u.value;
        });
        return base * getMultiplier();
    }

    function getPassive() {
        let base = 0;
        UPGRADES.forEach(u => {
            if (u.effect === 'passive') base += upgrades[u.id] * u.value;
        });
        return base * getMultiplier();
    }

    function getCritChance() {
        let chance = 0;
        UPGRADES.forEach(u => {
            if (u.effect === 'crit') chance += upgrades[u.id] * u.value;
        });
        return Math.min(chance, 0.95);
    }

    function getPrestigeCost() {
        return Math.floor(1000000 * Math.pow(3, prestigeLevel));
    }

    function getEventBonus() {
        currentEvent = getActiveEvent();
        return currentEvent.bonus;
    }

    function saveGame() {
        try {
            localStorage.setItem('clickerSave', JSON.stringify({
                points, prestigeLevel, prestigeBonus, totalClicks, totalCrits,
                upgrades, pets, equippedPets, usedCodes,
                rewardTimer, rewardReady, rewardPoints, boostMult, boostTimer,
                achievements, miniGameWins
            }));
        } catch (e) {}
    }

    function loadGame() {
        try {
            const raw = localStorage.getItem('clickerSave');
            if (!raw) return;
            const data = JSON.parse(raw);
            points = data.points || 0;
            prestigeLevel = data.prestigeLevel || 0;
            prestigeBonus = data.prestigeBonus || 1;
            totalClicks = data.totalClicks || 0;
            totalCrits = data.totalCrits || 0;
            if (data.upgrades) {
                UPGRADES.forEach(u => {
                    upgrades[u.id] = data.upgrades[u.id] || 0;
                });
            }
            pets = data.pets || [];
            equippedPets = data.equippedPets || [];
            usedCodes = data.usedCodes || [];
            rewardTimer = data.rewardTimer || 300;
            rewardReady = data.rewardReady || false;
            rewardPoints = data.rewardPoints || 0;
            boostMult = data.boostMult || 1;
            boostTimer = data.boostTimer || 0;
            if (data.achievements) {
                for (const [id, val] of Object.entries(data.achievements)) {
                    if (achievements[id]) achievements[id].unlocked = val.unlocked;
                }
            }
            miniGameWins = data.miniGameWins || 0;
            updateUI();
            renderPets();
            updateReward();
            renderAchievements();
            updateEventDisplay();
        } catch (e) {}
    }

    function updateUI() {
        const perClick = getPerClick();
        const passive = getPassive();
        const cost = getPrestigeCost();
        const eventBonus = getEventBonus();

        const displayPoints = Math.floor(points * eventBonus);

        heroPoints.textContent = fmt(displayPoints);
        heroPower.textContent = fmt(perClick * eventBonus);
        heroPassive.textContent = fmt(passive * eventBonus);
        heroPrestige.textContent = prestigeLevel;

        gPoints.textContent = fmt(displayPoints);
        gPower.textContent = fmt(perClick * eventBonus);
        gPassive.textContent = fmt(passive * eventBonus);
        gPrestige.textContent = prestigeLevel;

        const old = gPointsDisplay.textContent;
        gPointsDisplay.textContent = fmt(displayPoints);
        if (old !== gPointsDisplay.textContent) {
            gPointsDisplay.classList.remove('bump');
            void gPointsDisplay.offsetWidth;
            gPointsDisplay.classList.add('bump');
        }

        gPreInfo.textContent = prestigeLevel;
        gPreBonus.textContent = 'x' + prestigeBonus.toFixed(1);
        gPreCost.textContent = fmt(cost);

        const pb = document.getElementById('gPrestigeBtn');
        if (points >= cost) {
            pb.disabled = false;
            pb.textContent = '⭐ ПРЕСТИЖ';
        } else {
            pb.disabled = true;
            pb.textContent = '⭐ Нужно ' + fmt(cost);
        }

        renderShop();
        updateReward();
        updateEventDisplay();
        checkAchievements();
        saveGame();
    }

    function renderShop() {
        shopGrid.innerHTML = '';
        UPGRADES.forEach(u => {
            const level = upgrades[u.id] || 0;
            const cost = Math.floor(u.baseCost * Math.pow(u.costMult, level));
            const canBuy = points >= cost;

            const div = document.createElement('div');
            div.className = 'game-shop-item';
            const btnClass = canBuy ? 'ok' : 'no';
            div.innerHTML = `
                        <div class="name">${u.icon} ${u.name}</div>
                        <div class="effect">+${u.value} ${u.effect === 'multiplier' ? '×' : u.effect === 'passive' ? 'пасс/с' : u.effect === 'crit' ? '%' : 'за клик'}</div>
                        <div class="cost">💰 ${fmt(cost)}</div>
                        <div class="level">УР ${level}</div>
                        <button class="buy-btn ${btnClass}" ${canBuy ? '' : 'disabled'}>
                            ${canBuy ? 'КУПИТЬ ✅' : '❌'}
                            <span class="sub">${canBuy ? 'доступно' : 'нужно ' + fmt(cost - points)}</span>
                        </button>
                    `;
            const btn = div.querySelector('.buy-btn');
            btn.addEventListener('click', () => {
                const costNow = Math.floor(u.baseCost * Math.pow(u.costMult, upgrades[u.id] || 0));
                if (points >= costNow) {
                    points -= costNow;
                    upgrades[u.id] = (upgrades[u.id] || 0) + 1;
                    playClickSound();
                    showToast(`✅ ${u.name} улучшен до ${upgrades[u.id]} уровня!`, 'success');
                    updateUI();
                } else {
                    showToast(`❌ Не хватает ${fmt(costNow - points)} очков`, 'error');
                }
            });
            shopGrid.appendChild(div);
        });
    }

    function renderPets() {
        petsGrid.innerHTML = '';
        if (pets.length === 0) {
            petsGrid.innerHTML =
                '<div style="color:rgba(255,255,255,0.2);font-size:12px;grid-column:1/-1;text-align:center;padding:12px;">Нет питомцев 🥚</div>';
            return;
        }
        for (let i = 0; i < pets.length; i++) {
            const pet = pets[i];
            const r = getRarity(pet.rarity);
            const isEq = equippedPets.includes(i);

            const div = document.createElement('div');
            div.className = 'modal-pet' + (isEq ? ' eq' : '');
            div.innerHTML = `
                        <div class="icon">${pet.icon}</div>
                        <div class="name">${pet.name}</div>
                        <div class="rarity" style="color:${r.color}">${r.name}</div>
                        <div class="bonus">+${r.mult}</div>
                        <button class="eq-btn ${isEq ? 'off' : 'on'}">${isEq ? 'СНЯТЬ' : 'НАДЕТЬ'}</button>
                    `;
            const btn = div.querySelector('.eq-btn');
            btn.addEventListener('click', () => {
                if (isEq) {
                    equippedPets = equippedPets.filter(idx => idx !== i);
                    showToast('❌ Питомец снят', 'success');
                } else {
                    if (equippedPets.length >= MAX_EQUIPPED) {
                        showToast('❌ Максимум ' + MAX_EQUIPPED + ' питомцев!', 'error');
                        return;
                    }
                    equippedPets.push(i);
                    showToast('✅ ' + pet.name + ' экипирован!', 'success');
                }
                renderPets();
                updateUI();
            });
            petsGrid.appendChild(div);
        }
    }

    function updateReward() {
        const mins = Math.floor(rewardTimer / 60);
        const secs = Math.floor(rewardTimer % 60);
        rewardTimerEl.textContent = mins + ':' + (secs < 10 ? '0' : '') + secs;
        if (rewardReady) {
            claimBtn.disabled = false;
            claimBtn.textContent = '🎁 ЗАБРАТЬ (+' + fmt(rewardPoints) + ')';
        } else {
            claimBtn.disabled = true;
            claimBtn.textContent = '⏳ ' + Math.floor(rewardTimer) + 'с';
        }
    }

    // ─── ПЕРЕКЛЮЧЕНИЕ ЭКРАНОВ ───
    const mainScreen = document.getElementById('mainScreen');
    const gameScreen = document.getElementById('gameScreen');
    const heroSection = document.getElementById('heroSection');
    const infoSection = document.getElementById('info');

    document.getElementById('playBtn').addEventListener('click', function() {
        heroSection.classList.add('hidden');
        infoSection.classList.add('hidden');
        gameScreen.classList.add('active');
        loadGame();
        setTimeout(() => {
            showToast('🚀 Добро пожаловать в игру! Кликай!', 'info');
            playClickSound();
        }, 400);
    });

    document.getElementById('backBtn').addEventListener('click', function() {
        gameScreen.classList.remove('active');
        heroSection.classList.remove('hidden');
        infoSection.classList.remove('hidden');
        window.scrollTo({ top: 0, behavior: 'smooth' });
        showToast('👋 Возвращайся скорее!', 'info');
    });

    // ─── КЛИК ───
    document.getElementById('gameClickBtn').addEventListener('click', function(e) {
        const perClick = getPerClick();
        const eventBonus = getEventBonus();
        let earned = perClick * boostMult * eventBonus;
        let isCrit = false;

        if (Math.random() < getCritChance()) {
            earned *= 10;
            isCrit = true;
            totalCrits++;
        }

        points += earned;
        totalClicks++;
        playClickSound();
        updateUI();

        this.style.transform = 'scale(0.88)';
        setTimeout(() => { this.style.transform = ''; }, 150);

        const rect = this.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const emojis = ['✨', '💫', '⚡', '🌟'];
        for (let i = 0; i < 8; i++) {
            const el = document.createElement('div');
            el.className = 'click-pop';
            el.textContent = isCrit ? '💥' : emojis[Math.floor(Math.random() * emojis.length)];
            el.style.left = (cx + (Math.random() - 0.5) * 100) + 'px';
            el.style.top = (cy + (Math.random() - 0.5) * 100) + 'px';
            el.style.fontSize = (isCrit ? 32 : 16 + Math.random() * 18) + 'px';
            el.style.color = isCrit ? '#FF6B6B' : '#A57AFF';
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 800);
        }

        if (isCrit) {
            showToast('💥 КРИТ! ×10 урона!', 'success');
        }
    });

    // ─── ПРЕСТИЖ ───
    document.getElementById('gPrestigeBtn').addEventListener('click', function() {
        const cost = getPrestigeCost();
        if (points < cost) {
            showToast(`❌ Нужно ${fmt(cost)} очков для престижа`, 'error');
            return;
        }
        points = 0;
        prestigeLevel++;
        prestigeBonus = 1 + prestigeLevel * 0.5;
        UPGRADES.forEach(u => upgrades[u.id] = 0);
        pets = [];
        equippedPets = [];
        rewardTimer = 300;
        rewardReady = false;
        rewardPoints = 0;
        playPrestigeSound();
        showToast(`⭐ ПРЕСТИЖ! Уровень ${prestigeLevel}! x${prestigeBonus.toFixed(1)}`, 'success');
        updateUI();
        renderPets();
        saveGame();
    });

    // ─── МАГАЗИН ТОГГЛ ───
    let shopOpen = true;
    document.getElementById('shopToggle').addEventListener('click', () => {
        shopOpen = !shopOpen;
        document.getElementById('shopBody').classList.toggle('open');
        document.getElementById('shopArrow').classList.toggle('open');
    });
    document.getElementById('shopBody').classList.add('open');

    // ─── МОДАЛКИ ───
    function openModal(m) { m.classList.add('active'); }

    function closeModal(m) { m.classList.remove('active'); }

    document.getElementById('openPetsBtn').addEventListener('click', () => { openModal(document.getElementById('petsModal'));
        renderPets(); });
    document.getElementById('closePetsModal').addEventListener('click', () => closeModal(document.getElementById('petsModal')));
    document.getElementById('openRewardBtn').addEventListener('click', () => { openModal(document.getElementById('rewardModal'));
        updateReward();
        updateEventDisplay(); });
    document.getElementById('closeRewardModal').addEventListener('click', () => closeModal(document.getElementById(
        'rewardModal')));
    document.getElementById('openCodesBtn').addEventListener('click', () => openModal(document.getElementById('codesModal')));
    document.getElementById('closeCodesModal').addEventListener('click', () => closeModal(document.getElementById(
        'codesModal')));

    document.getElementById('openAchievementsBtn').addEventListener('click', () => {
        openModal(document.getElementById('achievementsModal'));
        renderAchievements();
    });
    document.getElementById('closeAchievementsModal').addEventListener('click', () => closeModal(document.getElementById(
        'achievementsModal')));

    document.getElementById('openMiniGameBtn').addEventListener('click', () => {
        openModal(document.getElementById('miniGameModal'));
        initMiniGame();
    });
    document.getElementById('closeMiniGameModal').addEventListener('click', () => closeModal(document.getElementById(
        'miniGameModal')));

    // ─── МУЗЫКАЛЬНАЯ МОДАЛКА ───
    document.getElementById('openMusicBtn').addEventListener('click', () => {
        openModal(document.getElementById('musicModal'));
    });
    document.getElementById('closeMusicModal').addEventListener('click', () => closeModal(document.getElementById(
        'musicModal')));

    // Кнопка с нотой на главном экране тоже открывает музыку
    document.getElementById('musicControl').addEventListener('click', () => {
        // Проверяем, открыта ли игра
        if (gameScreen.classList.contains('active')) {
            openModal(document.getElementById('musicModal'));
        } else {
            // Если на главном экране — просто прокручиваем к википедии
            document.getElementById('info').scrollIntoView({ behavior: 'smooth' });
            setTimeout(() => {
                showToast('🎵 Нажми "ИГРАТЬ", а затем кнопку "Музыка" в игре!', 'info');
            }, 500);
        }
    });

    [document.getElementById('petsModal'), document.getElementById('rewardModal'), document.getElementById('codesModal'),
        document.getElementById('achievementsModal'), document.getElementById('miniGameModal'),
        document.getElementById('musicModal')
    ].forEach(m => {
        m.addEventListener('click', (e) => { if (e.target === m) closeModal(m); });
    });

    // ─── ЯЙЦО ───
    document.getElementById('eggBtn').addEventListener('click', () => {
        const cost = 10000 + pets.length * 5000;
        if (points < cost) {
            showToast(`❌ Нужно ${fmt(cost - points)} очков для яйца`, 'error');
            return;
        }
        points -= cost;

        const roll = Math.random() * 100;
        let rarityId = 'common';
        if (roll < 0.5) rarityId = 'secret';
        else if (roll < 2) rarityId = 'divine';
        else if (roll < 6) rarityId = 'legendary';
        else if (roll < 15) rarityId = 'mythic';
        else if (roll < 35) rarityId = 'epic';
        else if (roll < 65) rarityId = 'rare';

        const species = PET_SPECIES[rarityId];
        const pick = species[Math.floor(Math.random() * species.length)];
        const newPet = { name: pick.name, icon: pick.icon, rarity: rarityId };
        pets.push(newPet);

        const r = getRarity(rarityId);
        playClickSound();
        showToast(`🥚 ${r.name} питомец: ${pick.icon} ${pick.name}!`, 'success');
        if (rarityId === 'secret') {
            setTimeout(() => {
                showToast('🌟 СЕКРЕТНЫЙ! Ты легенда!', 'success');
                playAchievementSound();
            }, 800);
        }
        renderPets();
        updateUI();
    });

    // ─── НАГРАДА ───
    document.getElementById('claimBtn').addEventListener('click', () => {
        if (!rewardReady) {
            showToast('❌ Награда ещё не готова', 'error');
            return;
        }
        points += rewardPoints;
        rewardReady = false;
        rewardPoints = 0;
        rewardTimer = 300;
        playBoostSound();
        showToast(`🎁 +${fmt(rewardPoints)} очков!`, 'success');
        if (Math.random() < 0.3) {
            boostMult = 2;
            boostTimer = 30;
            playBoostSound();
            showToast('⚡ БУСТЕР x2 на 30 сек!', 'success');
        }
        updateUI();
        updateReward();
    });

    // ─── КОДЫ ───
    document.getElementById('redeemBtn').addEventListener('click', () => {
        const input = document.getElementById('codeInput');
        const code = input.value.toUpperCase().trim();
        if (!code) { showToast('❌ Введи код', 'error'); return; }
        if (usedCodes.includes(code)) { showToast('❌ Код уже использован', 'error'); return; }

        const data = CODES[code];
        if (!data) { showToast('❌ Неверный код', 'error'); return; }

        usedCodes.push(code);
        if (data.points) {
            points += data.points;
            playBoostSound();
            showToast(`✅ +${fmt(data.points)} очков!`, 'success');
        }
        if (data.mult) {
            boostMult = data.mult;
            boostTimer = data.mult === 2 ? 300 : 180;
            playBoostSound();
            showToast(`✅ Бустер x${data.mult} активирован!`, 'success');
        }
        input.value = '';
        updateUI();
        saveGame();
    });

    document.getElementById('codeInput').addEventListener('keydown', (e) => {
        if (e.key === 'Enter') document.getElementById('redeemBtn').click();
    });

    // ─── МИНИ-ИГРА ───
    let miniGameCards = [];
    let selectedCards = [];
    let matchedPairs = 0;
    let moves = 0;
    let timer = 0;
    let timerInterval = null;
    let isGameFinished = false;

    const emojis = ['🍎', '🍋', '🍇', '🍉', '🍒', '🍑', '🍓', '🥝'];

    function initMiniGame() {
        document.getElementById('movesCount').textContent = '0';
        document.getElementById('pairsFound').textContent = '0/8';
        document.getElementById('timerDisplay').textContent = '0';
        moves = 0;
        matchedPairs = 0;
        selectedCards = [];
        isGameFinished = false;
        clearInterval(timerInterval);
        timer = 0;
        timerInterval = setInterval(() => {
            timer++;
            document.getElementById('timerDisplay').textContent = timer;
        }, 1000);

        const deck = [...emojis, ...emojis];
        for (let i = deck.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [deck[i], deck[j]] = [deck[j], deck[i]];
        }
        miniGameCards = deck.map((emoji, index) => ({
            id: index,
            emoji: emoji,
            flipped: false,
            matched: false
        }));

        renderMiniGame();
    }

    function renderMiniGame() {
        const grid = document.getElementById('miniGameGrid');
        grid.innerHTML = '';
        miniGameCards.forEach((card, index) => {
            const div = document.createElement('div');
            div.className = 'mini-game-card';
            if (card.matched) {
                div.classList.add('matched');
                div.textContent = card.emoji;
            } else if (card.flipped) {
                div.classList.add('selected');
                div.textContent = card.emoji;
            } else {
                div.textContent = '❓';
            }
            div.dataset.index = index;
            div.addEventListener('click', () => handleCardClick(index));
            grid.appendChild(div);
        });
    }

    function handleCardClick(index) {
        if (isGameFinished) return;
        const card = miniGameCards[index];
        if (card.matched || card.flipped || selectedCards.length >= 2) return;

        card.flipped = true;
        selectedCards.push(index);
        renderMiniGame();

        if (selectedCards.length === 2) {
            moves++;
            document.getElementById('movesCount').textContent = moves;
            const idx1 = selectedCards[0];
            const idx2 = selectedCards[1];
            const card1 = miniGameCards[idx1];
            const card2 = miniGameCards[idx2];

            if (card1.emoji === card2.emoji) {
                card1.matched = true;
                card2.matched = true;
                matchedPairs++;
                document.getElementById('pairsFound').textContent = matchedPairs + '/8';
                selectedCards = [];
                playClickSound();
                renderMiniGame();

                if (matchedPairs === 8) {
                    isGameFinished = true;
                    clearInterval(timerInterval);
                    playWinSound();
                    const bonus = 5000;
                    points += bonus;
                    miniGameWins++;
                    showToast(`🎉 Победа! +${fmt(bonus)} очков! 🎉`, 'success');
                    updateUI();
                    setTimeout(() => {
                        document.getElementById('closeMiniGameModal').click();
                    }, 2000);
                }
            } else {
                setTimeout(() => {
                    card1.flipped = false;
                    card2.flipped = false;
                    selectedCards = [];
                    renderMiniGame();
                }, 600);
            }
        }
    }

    document.getElementById('resetMiniGame').addEventListener('click', initMiniGame);

    // ─── ПАССИВНЫЙ ДОХОД ───
    setInterval(() => {
        const passive = getPassive();
        const eventBonus = getEventBonus();
        if (passive > 0) {
            points += passive * boostMult * eventBonus;
        }

        if (!rewardReady) {
            rewardTimer--;
            if (rewardTimer <= 0) {
                rewardReady = true;
                rewardPoints = Math.floor(500 * (1 + prestigeLevel * 0.5) * (1 + Math.random() * 0.4));
                rewardTimer = 300;
                playBoostSound();
                showToast('🎁 Награда готова! Забери!', 'success');
            }
        }

        if (boostTimer > 0) {
            boostTimer--;
            if (boostTimer <= 0) {
                boostMult = 1;
                showToast('⏳ Бустер закончился', 'info');
            }
        }

        updateUI();
        updateReward();
    }, 1000);

    // ─── ПАСХАЛКА ───
    let clickCount = 0;
    let lastClickTime = 0;

    document.getElementById('clickerLogo').addEventListener('click', function(e) {
        const now = Date.now();
        if (now - lastClickTime > 1000) clickCount = 0;
        clickCount++;
        lastClickTime = now;

        this.style.transform = 'scale(0.92)';
        setTimeout(() => { this.style.transform = ''; }, 150);

        if (clickCount >= 10) {
            clickCount = 0;
            const overlay = document.createElement('div');
            overlay.style.cssText = `
                        position: fixed; inset: 0; z-index: 999;
                        display: flex; justify-content: center; align-items: center;
                        background: rgba(0,0,0,0.4); backdrop-filter: blur(16px);
                        animation: fadeOverlay 0.5s ease;
                    `;
            overlay.innerHTML = `
                        <div style="background:rgba(20,16,31,0.7);backdrop-filter:blur(30px);border:2px solid rgba(130,90,255,0.1);border-radius:24px;padding:30px 40px;max-width:440px;width:90%;text-align:center;animation:modalIn 0.5s ease;">
                            <div style="font-size:56px;">🎭</div>
                            <div style="font-size:24px;font-weight:800;color:#FFD700;">ТЫ НАШЁЛ ДЕННИ!</div>
                            <div style="font-size:14px;color:#A57AFF;margin:6px 0 12px;">1 in 10 000 000 000 000 000</div>
                            <p style="color:rgba(255,255,255,0.7);font-size:13px;line-height:1.6;">🔥 Ты — один из триллиона!<br />Денни пришёл из параллельной вселенной,<br />чтобы сказать: <strong>ты легенда!</strong></p>
                            <button onclick="this.closest('div').parentElement.remove()" style="margin-top:16px;padding:8px 32px;background:linear-gradient(135deg,#825AFF,#6A3FD4);border:none;border-radius:30px;color:#fff;font-size:14px;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;">✧ ЗНАЮ ✧</button>
                        </div>
                    `;
            document.body.appendChild(overlay);
            overlay.addEventListener('click', (e) => { if (e.target === overlay) overlay.remove(); });

            for (let i = 0; i < 50; i++) {
                setTimeout(() => {
                    const star = document.createElement('div');
                    star.textContent = ['✦', '✧', '⭐', '✨', '🌟'][Math.floor(Math.random() * 5)];
                    star.style.cssText = `
                                position: fixed; left: ${Math.random() * 100}vw; top: -20px;
                                font-size: ${16 + Math.random() * 20}px;
                                color: ${['#FFD700','#A57AFF','#FF6B9D','#46DC78','#46A5FF'][Math.floor(Math.random() * 5)]};
                                pointer-events: none; z-index: 1000;
                                animation: starFall ${1 + Math.random() * 1.5}s linear forwards;
                            `;
                    document.body.appendChild(star);
                    setTimeout(() => star.remove(), 3000);
                }, i * 40);
            }
            playAchievementSound();
            showToast('🎭 Ты нашёл Денни! Ты легенда!', 'success');
        }
    });

    // ─── ЗАГРУЗКА ───
    loadGame();
    renderPets();
    renderAchievements();
    updateEventDisplay();
    setTimeout(() => showToast('👋 Привет! Нажми "ИГРАТЬ" чтобы начать!', 'info'), 600);
</script>

</body>
</html>
