<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>👆 CLICKER · C418 Edition</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #080810;
            color: #fff;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            overflow-x: hidden;
            user-select: none;
            -webkit-font-smoothing: antialiased;
        }

        ::-webkit-scrollbar {
            width: 4px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(130, 90, 255, 0.3);
            border-radius: 10px;
        }

        #particlesCanvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
        }

        .hero {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 20px;
            position: relative;
            z-index: 10;
            animation: fadeUp 1.2s ease-out;
            transition: opacity 0.6s ease, transform 0.6s ease;
        }

        .hero.hidden {
            opacity: 0;
            transform: scale(1.04);
            pointer-events: none;
            position: fixed;
            inset: 0;
        }

        @keyframes fadeUp {
            0% { opacity: 0; transform: translateY(30px); }
            100% { opacity: 1; transform: translateY(0); }
        }

        .hero h1 {
            font-size: 72px;
            font-weight: 900;
            background: linear-gradient(135deg, #825AFF, #A57AFF, #FF6B9D);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -2px;
            animation: pulseGlow 3s ease-in-out infinite;
            cursor: pointer;
        }

        @keyframes pulseGlow {
            0%, 100% { filter: drop-shadow(0 0 30px rgba(130, 90, 255, 0.2)); }
            50% { filter: drop-shadow(0 0 70px rgba(130, 90, 255, 0.5)); }
        }

        .hero .subtitle {
            font-size: 18px;
            color: rgba(255, 255, 255, 0.4);
            margin-top: 8px;
            letter-spacing: 6px;
            font-weight: 300;
        }

        .btn-play {
            display: inline-block;
            margin-top: 40px;
            padding: 18px 56px;
            font-size: 18px;
            font-weight: 600;
            color: #fff;
            background: linear-gradient(135deg, #825AFF, #6A3FD4);
            border: none;
            border-radius: 60px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            box-shadow: 0 0 40px rgba(130, 90, 255, 0.15);
            letter-spacing: 1px;
            font-family: 'Inter', sans-serif;
        }

        .btn-play:hover {
            transform: scale(1.06);
            box-shadow: 0 0 60px rgba(130, 90, 255, 0.3);
        }

        .btn-play:active {
            transform: scale(0.95);
        }

        .hero-stats {
            margin-top: 30px;
            display: flex;
            justify-content: center;
            gap: 40px;
            color: rgba(255, 255, 255, 0.3);
            font-size: 13px;
            letter-spacing: 1px;
            flex-wrap: wrap;
        }

        .hero-stats span {
            color: #A57AFF;
            font-weight: 600;
        }

        .scroll-down {
            margin-top: 50px;
            font-size: 28px;
            animation: bob 1.8s infinite;
            opacity: 0.3;
            cursor: pointer;
        }

        .scroll-down a {
            color: #825AFF;
            text-decoration: none;
        }

        @keyframes bob {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(10px); }
        }

        .info-section {
            padding: 60px 20px 80px;
            max-width: 960px;
            margin: 0 auto;
            background: rgba(12, 12, 26, 0.5);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 40px 40px 0 0;
            border: 1px solid rgba(130, 90, 255, 0.06);
            box-shadow: 0 -20px 60px rgba(0, 0, 0, 0.4);
            position: relative;
            z-index: 20;
            transition: opacity 0.6s ease, transform 0.6s ease;
        }

        .info-section.hidden {
            opacity: 0;
            transform: translateY(40px);
            pointer-events: none;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
        }

        .info-section h2 {
            font-size: 36px;
            font-weight: 700;
            background: linear-gradient(135deg, #A57AFF, #FF6B9D);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 30px;
            text-align: center;
        }

        .info-section p {
            font-size: 17px;
            line-height: 1.8;
            color: rgba(255, 255, 255, 0.7);
            margin-bottom: 20px;
            text-align: justify;
        }

        .info-section .highlight {
            color: #A57AFF;
            font-weight: 600;
        }
        .info-section .accent {
            color: #46DC78;
            font-weight: 600;
        }
        .info-section .pink {
            color: #FF6B9D;
            font-weight: 600;
        }
        .info-section .gold {
            color: #FFCD37;
            font-weight: 600;
        }

        .wiki-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
            margin: 24px 0;
        }

        .wiki-block {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            padding: 16px 18px;
            border-radius: 14px;
            border: 1px solid rgba(130, 90, 255, 0.05);
            transition: 0.3s;
        }

        .wiki-block:hover {
            border-color: rgba(130, 90, 255, 0.1);
            background: rgba(255, 255, 255, 0.05);
        }

        .wiki-block .title {
            font-size: 15px;
            font-weight: 700;
            color: #A57AFF;
            margin-bottom: 4px;
        }

        .wiki-block .desc {
            font-size: 12.5px;
            color: rgba(255, 255, 255, 0.5);
            line-height: 1.6;
        }

        .wiki-block .desc strong {
            color: rgba(255, 255, 255, 0.85);
        }

        .wiki-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
            margin-top: 6px;
        }

        .wiki-tags span {
            background: rgba(130, 90, 255, 0.08);
            padding: 2px 10px;
            border-radius: 12px;
            font-size: 9px;
            color: #A57AFF;
            font-weight: 600;
        }

        .wiki-list {
            list-style: none;
            padding: 0;
            margin: 4px 0 0;
        }

        .wiki-list li {
            padding: 2px 0 2px 14px;
            position: relative;
            font-size: 12.5px;
            color: rgba(255, 255, 255, 0.5);
            line-height: 1.6;
        }

        .wiki-list li::before {
            content: '▸';
            position: absolute;
            left: 0;
            color: #A57AFF;
        }

        .wiki-list li strong {
            color: rgba(255, 255, 255, 0.85);
        }

        .back-top {
            display: block;
            margin: 40px auto 10px;
            text-align: center;
            color: rgba(255, 255, 255, 0.3);
            font-size: 13px;
            text-decoration: none;
            transition: 0.3s;
            cursor: pointer;
        }

        .back-top:hover {
            color: #A57AFF;
        }

        #gameScreen {
            position: fixed;
            inset: 0;
            z-index: 50;
            display: none;
            flex-direction: column;
            align-items: center;
            background: rgba(10, 10, 18, 0.92);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            overflow-y: auto;
            padding: 16px 16px 30px;
            animation: gameIn 0.5s ease;
        }

        #gameScreen.active {
            display: flex;
        }

        @keyframes gameIn {
            0% { opacity: 0; transform: scale(0.96); }
            100% { opacity: 1; transform: scale(1); }
        }

        .game-top {
            position: sticky;
            top: 0;
            z-index: 30;
            width: 100%;
            max-width: 600px;
            padding: 10px 14px;
            background: rgba(10, 10, 18, 0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 16px;
            border: 1px solid rgba(130, 90, 255, 0.06);
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            gap: 6px 10px;
            margin-bottom: 12px;
        }

        .game-top .brand {
            font-weight: 700;
            font-size: 16px;
            background: linear-gradient(135deg, #A57AFF, #FF6B9D);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .game-top .top-actions {
            display: flex;
            gap: 4px;
            flex-wrap: wrap;
            align-items: center;
        }

        .game-top .top-actions button {
            background: rgba(130, 90, 255, 0.08);
            border: 1px solid rgba(130, 90, 255, 0.05);
            border-radius: 20px;
            color: rgba(255, 255, 255, 0.5);
            padding: 4px 12px;
            font-size: 11px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
            font-family: 'Inter', sans-serif;
        }

        .game-top .top-actions button:hover {
            background: rgba(130, 90, 255, 0.15);
            color: #A57AFF;
        }

        .game-top .back-btn {
            background: rgba(255, 60, 60, 0.06);
            border-color: rgba(255, 60, 60, 0.06);
            color: rgba(255, 255, 255, 0.3);
        }

        .game-top .back-btn:hover {
            background: rgba(255, 60, 60, 0.12);
            color: #FF6B6B;
        }

        .game-top .stats {
            display: flex;
            gap: 10px;
            font-size: 11px;
            color: rgba(255, 255, 255, 0.3);
            font-weight: 500;
            flex-wrap: wrap;
        }

        .game-top .stats span {
            color: #A57AFF;
        }

        .game-center {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100%;
            max-width: 600px;
        }

        .game-points {
            font-size: 42px;
            font-weight: 800;
            color: #fff;
            margin: 4px 0 2px;
            text-align: center;
            letter-spacing: -0.5px;
        }

        .game-points small {
            font-size: 14px;
            color: rgba(255, 255, 255, 0.3);
            font-weight: 400;
            display: block;
            letter-spacing: 2px;
        }

        .game-points .bump {
            animation: bump 0.2s ease;
        }

        @keyframes bump {
            0% { transform: scale(1); }
            50% { transform: scale(1.08); color: #A57AFF; }
            100% { transform: scale(1); }
        }

        .game-click {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: linear-gradient(135deg, #825AFF, #6A3FD4);
            border: none;
            color: #fff;
            font-size: 44px;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 0 60px rgba(130, 90, 255, 0.1);
            transition: all 0.06s ease;
            margin: 8px 0 12px;
            position: relative;
            font-family: 'Inter', sans-serif;
        }

        .game-click:active {
            transform: scale(0.88);
            box-shadow: 0 0 80px rgba(130, 90, 255, 0.2);
        }

        .game-click::after {
            content: '';
            position: absolute;
            inset: -6px;
            border-radius: 50%;
            background: linear-gradient(135deg, #825AFF, #FF6B9D);
            opacity: 0.06;
            z-index: -1;
            animation: glow 3s ease-in-out infinite;
        }

        @keyframes glow {
            0%, 100% { transform: scale(1); opacity: 0.06; }
            50% { transform: scale(1.1); opacity: 0.15; }
        }

        .game-shop {
            width: 100%;
            max-width: 600px;
            margin: 6px 0;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 14px;
            border: 1px solid rgba(130, 90, 255, 0.04);
            overflow: hidden;
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
        }

        .game-shop-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 14px;
            cursor: pointer;
            background: rgba(255, 255, 255, 0.01);
            transition: background 0.2s;
        }

        .game-shop-head:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        .game-shop-head h3 {
            font-size: 14px;
            color: #A57AFF;
            font-weight: 600;
        }

        .game-shop-head .arrow {
            font-size: 16px;
            color: rgba(255, 255, 255, 0.2);
            transition: transform 0.3s ease;
        }

        .game-shop-head .arrow.open {
            transform: rotate(180deg);
        }

        .game-shop-body {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.35s ease;
        }

        .game-shop-body.open {
            max-height: 3000px;
        }

        .game-shop-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 8px;
            padding: 10px 14px 14px;
        }

        .game-shop-item {
            background: rgba(255, 255, 255, 0.02);
            padding: 10px;
            border-radius: 10px;
            border-left: 2px solid #825AFF;
            text-align: center;
            transition: all 0.15s ease;
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
        }

        .game-shop-item:hover {
            background: rgba(255, 255, 255, 0.04);
        }

        .game-shop-item .name {
            font-size: 13px;
            font-weight: 600;
            color: #e8e0f0;
        }

        .game-shop-item .effect {
            font-size: 10px;
            color: rgba(255, 255, 255, 0.3);
            margin: 2px 0;
        }

        .game-shop-item .cost {
            font-size: 12px;
            font-weight: 700;
            color: #FFCD37;
        }

        .game-shop-item .level {
            font-size: 10px;
            color: rgba(255, 255, 255, 0.2);
        }

        .game-shop-item .buy-btn {
            margin-top: 4px;
            padding: 4px 12px;
            border: none;
            border-radius: 6px;
            font-weight: 600;
            font-size: 11px;
            cursor: pointer;
            transition: all 0.15s ease;
            width: 100%;
            font-family: 'Inter', sans-serif;
        }

        .game-shop-item .buy-btn.ok {
            background: #46DC78;
            color: #0a0a12;
        }

        .game-shop-item .buy-btn.ok:hover {
            transform: scale(1.03);
        }

        .game-shop-item .buy-btn.no {
            background: rgba(255, 255, 255, 0.04);
            color: rgba(255, 255, 255, 0.2);
            cursor: not-allowed;
        }

        .game-shop-item .buy-btn .sub {
            display: block;
            font-size: 8px;
            opacity: 0.6;
            font-weight: 400;
        }

        .game-prestige {
            width: 100%;
            max-width: 600px;
            margin: 6px 0;
            padding: 10px 14px;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 12px;
            border: 1px solid rgba(180, 80, 255, 0.06);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 6px;
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
        }

        .game-prestige .info {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.3);
        }

        .game-prestige .info span {
            color: #B450FF;
            font-weight: 600;
        }

        .game-prestige .prestige-btn {
            padding: 5px 16px;
            border: none;
            border-radius: 8px;
            background: #B450FF;
            color: #fff;
            font-weight: 600;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s ease;
            font-family: 'Inter', sans-serif;
        }

        .game-prestige .prestige-btn:hover {
            transform: scale(1.04);
        }

        .game-prestige .prestige-btn:disabled {
            background: rgba(255, 255, 255, 0.04);
            color: rgba(255, 255, 255, 0.2);
            cursor: not-allowed;
        }

        .modal {
            position: fixed;
            inset: 0;
            z-index: 100;
            display: none;
            justify-content: center;
            align-items: center;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
        }

        .modal.active {
            display: flex;
        }

        .modal-box {
            background: rgba(20, 16, 31, 0.7);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border: 1px solid rgba(130, 90, 255, 0.08);
            border-radius: 20px;
            padding: 24px;
            max-width: 440px;
            width: 92%;
            max-height: 80vh;
            overflow-y: auto;
            position: relative;
            animation: modalIn 0.3s ease;
            box-shadow: 0 20px 80px rgba(0, 0, 0, 0.5);
        }

        @keyframes modalIn {
            0% { transform: scale(0.95) translateY(10px); opacity: 0; }
            100% { transform: scale(1) translateY(0); opacity: 1; }
        }

        .modal-box .close-modal {
            position: absolute;
            top: 10px;
            right: 14px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 50%;
            width: 32px;
            height: 32px;
            color: rgba(255, 255, 255, 0.3);
            font-size: 18px;
            cursor: pointer;
            transition: 0.2s;
            font-family: 'Inter', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .modal-box .close-modal:hover {
            color: #fff;
            background: rgba(255, 60, 60, 0.1);
            border-color: rgba(255, 60, 60, 0.2);
            transform: rotate(90deg);
        }

        .modal-box h2 {
            font-size: 20px;
            color: #A57AFF;
            margin-bottom: 12px;
            padding-right: 30px;
        }

        .modal-box .body {
            color: rgba(255, 255, 255, 0.7);
            font-size: 13px;
            line-height: 1.6;
        }

        .modal-pets-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
            gap: 8px;
            margin: 10px 0;
        }

        .modal-pet {
            background: rgba(255, 255, 255, 0.03);
            padding: 8px;
            border-radius: 10px;
            text-align: center;
            border: 1px solid rgba(130, 90, 255, 0.04);
            transition: 0.2s;
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
        }

        .modal-pet:hover {
            background: rgba(255, 255, 255, 0.05);
        }

        .modal-pet .icon {
            font-size: 24px;
        }
        .modal-pet .name {
            font-size: 10px;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.8);
        }
        .modal-pet .rarity {
            font-size: 8px;
        }
        .modal-pet .bonus {
            font-size: 9px;
            color: #46DC78;
        }
        .modal-pet.eq {
            border-color: #FFCD37;
            background: rgba(255, 215, 0, 0.04);
        }

        .modal-pet .eq-btn {
            margin-top: 3px;
            padding: 2px 10px;
            border: none;
            border-radius: 4px;
            font-size: 9px;
            font-weight: 600;
            cursor: pointer;
            width: 100%;
            font-family: 'Inter', sans-serif;
        }

        .modal-pet .eq-btn.on {
            background: #46A5FF;
            color: #fff;
        }
        .modal-pet .eq-btn.off {
            background: #FF6B6B;
            color: #fff;
        }

        .modal-btn {
            padding: 6px 18px;
            border: none;
            border-radius: 8px;
            background: #A57AFF;
            color: #fff;
            font-weight: 600;
            font-size: 12px;
            cursor: pointer;
            transition: 0.2s;
            font-family: 'Inter', sans-serif;
            margin: 4px 0;
        }

        .modal-btn:hover {
            transform: scale(1.04);
            background: #8a66e6;
        }

        .modal-reward-box {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
            padding: 12px;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 10px;
            border: 1px solid rgba(255, 215, 0, 0.04);
            margin: 10px 0;
        }

        .modal-reward-box .info {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.5);
        }
        .modal-reward-box .info span {
            color: #FFCD37;
            font-weight: 600;
        }

        .modal-reward-box .claim-btn {
            padding: 6px 20px;
            border: none;
            border-radius: 8px;
            background: #FFCD37;
            color: #0a0a12;
            font-weight: 600;
            font-size: 12px;
            cursor: pointer;
            transition: 0.2s;
            font-family: 'Inter', sans-serif;
        }

        .modal-reward-box .claim-btn:hover {
            transform: scale(1.04);
        }
        .modal-reward-box .claim-btn:disabled {
            background: rgba(255, 255, 255, 0.04);
            color: rgba(255, 255, 255, 0.2);
            cursor: not-allowed;
        }

        .modal-codes-box {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            margin: 10px 0;
        }

        .modal-codes-box input {
            flex: 1;
            padding: 8px 12px;
            border-radius: 8px;
            border: 1px solid rgba(42, 42, 58, 0.6);
            background: rgba(255, 255, 255, 0.03);
            color: #fff;
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            outline: none;
            min-width: 120px;
        }

        .modal-codes-box input:focus {
            border-color: #825AFF;
            box-shadow: 0 0 20px rgba(130, 90, 255, 0.05);
        }

        .modal-codes-box .redeem-btn {
            padding: 8px 18px;
            border: none;
            border-radius: 8px;
            background: #46DC78;
            color: #0a0a12;
            font-weight: 600;
            font-size: 12px;
            cursor: pointer;
            transition: 0.2s;
            font-family: 'Inter', sans-serif;
        }

